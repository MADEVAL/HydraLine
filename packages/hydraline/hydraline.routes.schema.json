{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://hydraline.dev/schemas/hydraline.routes.schema.json",
  "title": "Hydraline Route Manifest",
  "description": "Schema for the canonical route manifest hydraline.routes.yaml. Validated in CI.",
  "type": "object",
  "required": ["routes"],
  "additionalProperties": false,
  "properties": {
    "version": {
      "description": "Schema version (SemVer). Optional.",
      "type": "string",
      "pattern": "^\\d+\\.\\d+(\\.\\d+)?$"
    },
    "base_url": {
      "description": "Absolute base URL of the site for canonical/sitemap.",
      "type": "string",
      "format": "uri"
    },
    "routes": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/$defs/route" }
    }
  },
  "$defs": {
    "route": {
      "type": "object",
      "required": ["path", "mode"],
      "additionalProperties": false,
      "properties": {
        "path": {
          "description": "Route path (path-routing, no hash). Dynamic segments use :name.",
          "type": "string",
          "pattern": "^/[^#]*$"
        },
        "mode": {
          "description": "Render mode for the route.",
          "type": "string",
          "enum": ["app", "document", "hybrid"]
        },
        "metadata": { "$ref": "#/$defs/metadata" },
        "content_source": {
          "description": "Content source: 'widget' or 'widget:<Id>' (surface A, build-time extraction from Flutter widgets; :<Id> — optional page-builder) or 'dart_builder:<Id>' (surface B, pure-Dart builder). Not required for mode=app.",
          "type": "string",
          "pattern": "^(widget(:[A-Za-z_][A-Za-z0-9_]*(\\.[A-Za-z_][A-Za-z0-9_]*)*)?|dart_builder:[A-Za-z_][A-Za-z0-9_]*(\\.[A-Za-z_][A-Za-z0-9_]*)*)$"
        },
        "dynamic_segments": {
          "description": "Values of dynamic segments for SSG. Key = segment name without ':'.",
          "type": "object",
          "additionalProperties": {
            "type": "array",
            "items": { "type": "string", "minLength": 1 },
            "minItems": 1
          }
        },
        "noindex": {
          "description": "Explicit noindex (meta + X-Robots-Tag). Defaults to true for mode=app.",
          "type": "boolean"
        },
        "sitemap": {
          "description": "Whether to include the route in the sitemap. Defaults to false for mode=app.",
          "type": "boolean"
        }
      },
      "allOf": [
        {
          "description": "document/hybrid require content_source.",
          "if": { "properties": { "mode": { "enum": ["document", "hybrid"] } } },
          "then": { "required": ["content_source"] }
        }
      ]
    },
    "metadata": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "title": { "type": "string", "minLength": 1, "maxLength": 70 },
        "description": { "type": "string", "maxLength": 320 },
        "canonical": { "type": "string", "format": "uri-reference" },
        "lang": { "type": "string" },
        "robots": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "noindex": { "type": "boolean" },
            "nofollow": { "type": "boolean" }
          }
        },
        "open_graph": {
          "type": "object",
          "additionalProperties": true,
          "properties": {
            "title": { "type": "string" },
            "description": { "type": "string" },
            "type": { "type": "string" },
            "image": { "type": "string", "format": "uri-reference" },
            "url": { "type": "string", "format": "uri-reference" },
            "locale": { "type": "string" },
            "site_name": { "type": "string" }
          }
        },
        "twitter": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "card": { "type": "string", "enum": ["summary", "summary_large_image"] },
            "title": { "type": "string" },
            "description": { "type": "string" },
            "image": { "type": "string", "format": "uri-reference" },
            "site": { "type": "string" },
            "creator": { "type": "string" }
          }
        },
        "hreflang": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["hreflang", "href"],
            "additionalProperties": false,
            "properties": {
              "hreflang": { "type": "string" },
              "href": { "type": "string", "format": "uri-reference" }
            }
          }
        }
      }
    }
  }
}

# Hydraline - line-ending and binary policy.

# Normalize all text files to LF in the repository and on checkout.
* text=auto eol=lf

# Golden artefacts are byte-exact fixtures - git must never rewrite them (XP4).
**/goldens/** binary
**/test/**/goldens/** binary

# Binary assets.
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.webp binary
*.ico binary
*.ttf binary
*.otf binary
*.woff binary
*.woff2 binary
*.wasm binary
*.pdf binary
